# ===========================================
# ImmiAssist AI — Environment Configuration
# ===========================================

# ----- LLM API Keys -----
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-gemini-key

# ----- Model Configuration -----
CLASSIFIER_MODEL=gemini-2.0-flash
REASONING_MODEL=claude-sonnet-4-20250514
STRUCTURED_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-3-small

# ----- Database -----
DATABASE_URL=sqlite:///./immi_assist.db
# Production (Postgres):
# DATABASE_URL=postgresql+psycopg://immi:PASSWORD@db:5432/immi_assist
# POSTGRES_USER=immi
# POSTGRES_PASSWORD=generate-a-long-random-password
# POSTGRES_DB=immi_assist
# Pilot SQLite only (single worker): ALLOW_SQLITE_IN_PRODUCTION=true
ALLOW_SQLITE_IN_PRODUCTION=false

# ----- Vector Store -----
CHROMA_PERSIST_DIR=./data/chroma_db
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX=immi-assist

# ----- Application -----
APP_NAME=ImmiAssist AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key
# Separate preferred for Fernet encryption of provider API keys
ENCRYPTION_KEY=change-this-to-another-random-secret
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----- Google Auth -----
# OAuth 2.0 Web Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=
# API/tests only — UI uses Google + email/password register. Must be false in production.
AUTH_DEV_MODE=true

# ----- Email (welcome summary on registration) -----
# Leave SMTP_HOST empty to log welcome emails in development
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@immiassist.local
SMTP_USE_TLS=true
EMAIL_LOG_ONLY=true

# ----- Rate Limiting -----
FREE_TIER_DAILY_LIMIT=5
STARTER_TIER_DAILY_LIMIT=100

# ----- Admin -----
ADMIN_API_KEY=change-this-admin-key

# ----- Auth Hardening -----
ALLOW_PUBLIC_REGISTRATION=false
MAX_API_KEYS_PER_USER=3
MAX_REGISTRATIONS_PER_IP_PER_DAY=3

# ----- Knowledge Base -----
MIN_KNOWLEDGE_BASE_DOCUMENTS=10

# ----- LLM Resilience -----
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# ----- Observability -----
METRICS_ENABLED=true
METRICS_REQUIRE_ADMIN=false
# SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- Production Proxy / TLS -----
# SITE_ADDRESS=:80
# SITE_ADDRESS=immiassist.yourdomain.com
# ACME_EMAIL=ops@yourdomain.com
# PUBLIC_API_URL=https://immiassist.yourdomain.com/api/v1
# CORS_ORIGINS=https://immiassist.yourdomain.com
# UVICORN_WORKERS=2

# ----- Scheduled Refresh -----
INGEST_INTERVAL_HOURS=168

# ----- Stripe (Payments) -----
# STRIPE_SECRET_KEY=sk_test_your-stripe-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
