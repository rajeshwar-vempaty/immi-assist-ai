# ===========================================
# ImmiAssist AI — Environment Configuration
# ===========================================

# ----- LLM API Keys -----
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-gemini-key

# ----- Model Configuration -----
# Intent classifier (fast & cheap)
CLASSIFIER_MODEL=gemini-2.0-flash
# Complex reasoning (policy Q&A, RFE analysis)
REASONING_MODEL=claude-sonnet-4-20250514
# Structured output (checklists, timelines)
STRUCTURED_MODEL=gemini-2.0-flash
# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# ----- Database -----
DATABASE_URL=sqlite:///./immi_assist.db
# For production: postgresql://user:pass@host:5432/immi_assist

# ----- Vector Store -----
CHROMA_PERSIST_DIR=./data/chroma_db
# For production Pinecone:
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX=immi-assist

# ----- Application -----
APP_NAME=ImmiAssist AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key
# Separate preferred for Fernet encryption of provider API keys
ENCRYPTION_KEY=change-this-to-another-random-secret
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----- Google Auth -----
# OAuth 2.0 Web Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=
# Allow email/name login without Google (development only)
AUTH_DEV_MODE=true

# ----- Rate Limiting -----
FREE_TIER_DAILY_LIMIT=5
STARTER_TIER_DAILY_LIMIT=100

# ----- Admin -----
ADMIN_API_KEY=change-this-admin-key

# ----- Auth Hardening -----
ALLOW_PUBLIC_REGISTRATION=false
MAX_API_KEYS_PER_USER=3
MAX_REGISTRATIONS_PER_IP_PER_DAY=3

# ----- Knowledge Base -----
MIN_KNOWLEDGE_BASE_DOCUMENTS=10

# ----- LLM Resilience -----
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# ----- Observability -----
METRICS_ENABLED=true
# SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- Production Proxy / TLS -----
# SITE_ADDRESS=:80                         # local HTTP
# SITE_ADDRESS=immiassist.yourdomain.com   # automatic HTTPS
# ACME_EMAIL=ops@yourdomain.com
# PUBLIC_API_URL=https://immiassist.yourdomain.com/api/v1
# CORS_ORIGINS=https://immiassist.yourdomain.com

# ----- Scheduled Refresh -----
INGEST_INTERVAL_HOURS=168

# ----- Stripe (Payments) -----
# STRIPE_SECRET_KEY=sk_test_your-stripe-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
