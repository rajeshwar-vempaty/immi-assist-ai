# ===========================================
# ImmiAssist AI — Environment Configuration
# ===========================================

# ----- LLM API Keys -----
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-gemini-key

# ----- Model Configuration -----
# Intent classifier (fast & cheap)
CLASSIFIER_MODEL=gemini-2.0-flash
# Complex reasoning (policy Q&A, RFE analysis)
REASONING_MODEL=claude-sonnet-4-20250514
# Structured output (checklists, timelines)
STRUCTURED_MODEL=gemini-2.0-flash
# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# ----- Database -----
DATABASE_URL=sqlite:///./immi_assist.db
# For production: postgresql://user:pass@host:5432/immi_assist

# ----- Vector Store -----
CHROMA_PERSIST_DIR=./data/chroma_db
# For production Pinecone:
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX=immi-assist

# ----- Application -----
APP_NAME=ImmiAssist AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----- Rate Limiting -----
FREE_TIER_DAILY_LIMIT=5
STARTER_TIER_DAILY_LIMIT=100

# ----- Stripe (Payments) -----
# STRIPE_SECRET_KEY=sk_test_your-stripe-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
