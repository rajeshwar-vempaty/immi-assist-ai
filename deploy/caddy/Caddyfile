# ImmiAssist AI — Caddy reverse proxy
#
# SITE_ADDRESS examples:
#   :80                  → HTTP only (local)
#   immiassist.example.com → automatic HTTPS
#
# Publicly exposed: frontend + /api/* only.
# /docs, /redoc, /openapi.json, /metrics are NOT proxied (internal-only).

{
	email {$ACME_EMAIL}
}

(common) {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Block accidental public access to API docs / metrics via the edge
	@blocked path /docs /docs/* /redoc /redoc/* /openapi.json /metrics
	handle @blocked {
		respond "Not found" 404
	}

	@backend path /api/*
	handle @backend {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$SITE_ADDRESS::80} {
	import common
}
